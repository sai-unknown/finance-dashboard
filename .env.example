# Frontend API base URL
# - Local db.json API: http://localhost:5000
# - Custom backend URL: https://your-api.example.com
# - Vercel production: leave empty to use same-origin rewrites
REACT_APP_API_URL=

# Serverless API database URL (Neon/Postgres)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

